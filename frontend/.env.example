# Frontend Vite environment variables
# These are BUILD-TIME variables — they get baked into the JS bundle by Vite.
# Set the actual values in your Cloud Build trigger substitutions, NOT here.

# URL of the deployed backend Cloud Run service
# Example: https://backend-xxxx-uc.a.run.app
VITE_API_BASE_URL=http://localhost:5000

# Tenant slug used in every API request header (x-tenant-slug)
VITE_DEFAULT_TENANT_SLUG=demo
